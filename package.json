{
  "name": "claude-quota-widget",
  "version": "1.0.0",
  "description": "A beautiful macOS desktop quota widget for Claude",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.arnob.claudequotawidget",
    "productName": "Claude Quota Widget",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Install Claude Quota Widget",
      "contents": [
        {
          "x": 130,
          "y": 150,
          "type": "file"
        },
        {
          "x": 360,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
